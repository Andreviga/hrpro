{
  "name": "hrpro-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "worker": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "build": "tsc -p tsconfig.build.json",
    "lint": "npm run typecheck",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "start": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:sync:docker": "powershell -ExecutionPolicy Bypass -File ../scripts/prisma-sync-docker.ps1",
    "prisma:sync:docker:history": "powershell -ExecutionPolicy Bypass -File ../scripts/prisma-sync-docker.ps1 -SkipApply",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:seed:js": "node prisma/seed.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.8",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.8",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.8",
    "@nestjs/swagger": "^7.4.0",
    "@prisma/client": "^5.20.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.16.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "docx": "^8.5.0",
    "dotenv": "^16.4.5",
    "fast-xml-parser": "^5.5.1",
    "ioredis": "^5.4.1",
    "jszip": "^3.10.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.10.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.15.0",
    "playwright": "^1.58.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "swagger-ui-express": "^5.0.1",
    "tesseract.js": "^6.0.1",
    "xlsx": "^0.18.5"
  },
  "optionalDependencies": {
    "xsd-schema-validator": "^0.11.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.14.12",
    "@types/nodemailer": "^7.0.11",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.13.5",
    "@types/supertest": "^2.0.16",
    "jest": "^29.7.0",
    "prisma": "^5.20.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
