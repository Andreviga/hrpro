generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  rh
  manager
  employee
  intern
}

enum EmployeeStatus {
  active
  inactive
  pending_approval
  dismissed
}

enum SalaryType {
  hourly
  monthly
}

enum PayrollStatus {
  draft
  calculated
  closed
}

enum PayrollEventType {
  earning
  deduction
}

enum ContractType {
  clt
  temporary
  intern
}

enum ContractStatus {
  draft
  pending
  active
  inactive
}

enum BenefitType {
  transport
  meal
  other
}

enum RubricAssignmentType {
  fixed
  variable
}

enum ApprovalStatus {
  draft
  pending
  approved
  rejected
}

enum ImportStatus {
  pending
  processing
  completed
  failed
}

enum ImportItemStatus {
  ok
  error
}

enum TimeBankEntryType {
  credit
  debit
}

enum DocumentType {
  trct
  termo_quitacao
  aviso_previo
  recibo_ferias
  aviso_ferias
  holerite
  recibo_13
  recibo_plr
  outros
}

enum DocumentStatus {
  draft
  review
  approved
  signed
  finalized
  reopened
}

enum SignatureType {
  digital
  token
  biometric
}

enum TicketStatus {
  open
  in_progress
  resolved
  closed
}

enum TicketPriority {
  low
  medium
  high
  urgent
}

enum TicketCategory {
  payroll
  benefits
  technical
  other
}

enum EsocialDocumentType {
  event_xml
  lote_envio
  retorno_recepcao_lote
  retorno_processamento_lote
  retorno_processamento_evento
  consulta
  desconhecido
}

enum EsocialProcessingResult {
  success
  partial
  failed
  pending
  unknown
}

enum EsocialOccurrenceSeverity {
  ERROR
  WARNING
  INFO
  UNKNOWN
}

model Company {
  id        String   @id @default(cuid())
  name      String
  cnpj      String   @unique
  createdAt DateTime @default(now())

  users     User[]
  employees Employee[]
  employeeContracts EmployeeContract[]
  employeeSalaryHistory EmployeeSalaryHistory[]
  costCenters CostCenter[]
  rubrics   Rubric[]
  payrollRuns PayrollRun[]
  taxTableInss TaxTableInss[]
  taxTableIrrf TaxTableIrrf[]
  importBatches ImportBatch[]
  auditLogs AuditLog[]
  documentTemplates DocumentTemplate[]
  employeeDocuments EmployeeDocument[]
  documentVersions DocumentVersion[]
  supportTickets SupportTicket[]
  chatMessages   ChatMessage[]
  systemConfigs  SystemConfig[]
  esocialDocuments EsocialDocument[]
}

model User {
  id           String   @id @default(cuid())
  companyId    String
  fullName     String
  email        String   @unique
  passwordHash String
  role         UserRole
  employeeId   String?
  createdAt    DateTime @default(now())

  company  Company @relation(fields: [companyId], references: [id])
  employee Employee? @relation(fields: [employeeId], references: [id])
  auditLogs AuditLog[]
  documentSignatures DocumentSignature[]
}

model Employee {
  id           String         @id @default(cuid())
  companyId    String
  fullName     String
  cpf          String         @unique
  employerCnpj String?
  rg           String?
  birthDate    DateTime?
  motherName   String?
  email        String?
  phone        String?
  bankName     String?
  bankAgency   String?
  bankAccount  String?
  paymentMethod String?
  addressLine  String?
  city         String?
  state        String?
  zipCode      String?
  cityCode     String?
  employeeCode String?
  admissionDate DateTime?
  ctps         String?
  ctpsNumber   String?
  ctpsSeries   String?
  ctpsState    String?
  pis          String?
  socialName   String?
  gender       String?
  raceColor    String?
  maritalStatus String?
  educationLevel String?
  nationalityCode String?
  birthCountryCode String?
  birthState   String?
  birthCityCode String?
  rgIssuer     String?
  rgIssuerState String?
  rgIssueDate  DateTime?
  esocialCategoryCode String?
  esocialRegistrationType String?
  esocialRegimeType String?
  esocialAdmissionType String?
  esocialAdmissionIndicator String?
  esocialActivityNature String?
  esocialUnionCnpj String?
  esocialSalaryUnit String?
  esocialContractType String?
  esocialContractEndDate DateTime?
  esocialWeeklyHours Decimal?
  esocialWorkSchedule String?
  esocialHasDisability Boolean?
  esocialDisabilityType String?
  position     String
  department   String
  status       EmployeeStatus @default(pending_approval)
  salaryType   SalaryType
  baseSalary   Decimal?
  hourlyRate   Decimal?
  weeklyHours  Decimal?
  dependents   Int            @default(0)
  unionFee     Boolean        @default(false)
  transportVoucherValue Decimal? 
  mealVoucherValue Decimal?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?
  deletedBy    String?
  deletedReason String?

  company      Company @relation(fields: [companyId], references: [id])
  payrollResults PayrollResult[]
  timeBankEntries TimeBankEntry[]
  timeBankCloses  TimeBankClose[]
  dependentsList   EmployeeDependent[]
  contracts    EmployeeContract[]
  salaryHistory EmployeeSalaryHistory[]
  benefits     EmployeeBenefit[]
  rubricAssignments EmployeeRubric[]
  attachments  EmployeeAttachment[]
  users          User[]
  documents      EmployeeDocument[]
  documentSignatures DocumentSignature[]
  supportTickets SupportTicket[]
}

model CostCenter {
  id        String   @id @default(cuid())
  companyId String
  code      String
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  company   Company @relation(fields: [companyId], references: [id])
  contracts EmployeeContract[]

  @@unique([companyId, code])
}

model EmployeeDependent {
  id         String   @id @default(cuid())
  employeeId String
  fullName   String
  cpf        String?
  birthDate  DateTime?
  relationship String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  employee Employee @relation(fields: [employeeId], references: [id])
}

model EmployeeContract {
  id          String        @id @default(cuid())
  companyId   String
  employeeId  String
  costCenterId String?
  contractType ContractType
  position    String
  department  String
  salaryType  SalaryType
  baseSalary  Decimal?
  hourlyRate  Decimal?
  weeklyHours Decimal?
  effectiveFrom DateTime
  effectiveTo DateTime?
  status      ContractStatus @default(draft)
  approvalStatus ApprovalStatus @default(draft)
  approvedBy  String?
  approvedAt  DateTime?
  reason      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  company   Company @relation(fields: [companyId], references: [id])
  employee  Employee @relation(fields: [employeeId], references: [id])
  costCenter CostCenter? @relation(fields: [costCenterId], references: [id])
}

model EmployeeSalaryHistory {
  id          String        @id @default(cuid())
  companyId   String
  employeeId  String
  salaryType  SalaryType
  baseSalary  Decimal?
  hourlyRate  Decimal?
  weeklyHours Decimal?
  effectiveFrom DateTime
  effectiveTo DateTime?
  approvalStatus ApprovalStatus @default(draft)
  approvedBy  String?
  approvedAt  DateTime?
  reason      String?
  createdAt   DateTime @default(now())

  company  Company  @relation(fields: [companyId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])
}

model EmployeeBenefit {
  id          String      @id @default(cuid())
  employeeId  String
  type        BenefitType
  amount      Decimal
  effectiveFrom DateTime
  effectiveTo DateTime?
  approvalStatus ApprovalStatus @default(draft)
  approvedBy  String?
  approvedAt  DateTime?
  reason      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  employee Employee @relation(fields: [employeeId], references: [id])
}

model Rubric {
  id          String   @id @default(cuid())
  companyId   String
  code        String
  name        String
  description String?
  type        PayrollEventType
  formula     String?
  percentage  Decimal?
  fixedValue  Decimal?
  baseRubric  String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  assignments EmployeeRubric[]

  @@unique([companyId, code])
}

model EmployeeRubric {
  id          String   @id @default(cuid())
  employeeId  String
  rubricId    String
  assignmentType RubricAssignmentType
  amount      Decimal
  effectiveFrom DateTime
  effectiveTo DateTime?
  active      Boolean @default(true)
  createdAt   DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
  rubric   Rubric   @relation(fields: [rubricId], references: [id])
}

model EmployeeAttachment {
  id          String   @id @default(cuid())
  employeeId  String
  fileName    String
  mimeType    String
  storagePath String
  description String?
  uploadedBy  String?
  uploadedAt  DateTime @default(now())
  deletedAt   DateTime?

  employee Employee @relation(fields: [employeeId], references: [id])
}

model PayrollRun {
  id        String        @id @default(cuid())
  companyId String
  month     Int
  year      Int
  status    PayrollStatus @default(draft)
  version   Int           @default(1)
  createdAt DateTime      @default(now())
  closedAt  DateTime?

  company   Company @relation(fields: [companyId], references: [id])
  results   PayrollResult[]
  documents EmployeeDocument[]

  @@unique([companyId, month, year, version])
}

model PayrollResult {
  id              String   @id @default(cuid())
  payrollRunId    String
  employeeId      String
  grossSalary     Decimal
  totalDeductions Decimal
  netSalary       Decimal
  fgts            Decimal
  createdAt       DateTime @default(now())

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id])
  employee   Employee   @relation(fields: [employeeId], references: [id])
  events     PayrollEvent[]

  @@unique([payrollRunId, employeeId])
}

model PayrollEvent {
  id              String           @id @default(cuid())
  payrollResultId String
  code            String
  description     String
  type            PayrollEventType
  amount          Decimal

  payrollResult PayrollResult @relation(fields: [payrollResultId], references: [id])
}

model TaxTableInss {
  id        String   @id @default(cuid())
  companyId String
  month     Int
  year      Int
  minValue  Decimal
  maxValue  Decimal
  rate      Decimal
  deduction Decimal
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, month, year, minValue])
}

model TaxTableIrrf {
  id                String   @id @default(cuid())
  companyId         String
  month             Int
  year              Int
  minValue          Decimal
  maxValue          Decimal
  rate              Decimal
  deduction         Decimal
  dependentDeduction Decimal
  createdAt         DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, month, year, minValue])
}

model TimeBankEntry {
  id         String            @id @default(cuid())
  employeeId String
  date       DateTime
  minutes    Int
  type       TimeBankEntryType
  note       String?
  createdAt  DateTime          @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
}

model TimeBankClose {
  id         String   @id @default(cuid())
  employeeId String
  month      Int
  year       Int
  balanceMinutes Int
  approvedBy String?
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, month, year])
}

model ImportBatch {
  id            String        @id @default(cuid())
  companyId     String
  fileName      String
  status        ImportStatus  @default(pending)
  processedRows Int           @default(0)
  failedRows    Int           @default(0)
  createdAt     DateTime      @default(now())

  company Company @relation(fields: [companyId], references: [id])
  items   ImportItem[]
}

model ImportItem {
  id         String           @id @default(cuid())
  batchId    String
  sheet      String
  rowNumber  Int
  status     ImportItemStatus
  message    String
  createdAt  DateTime @default(now())

  batch ImportBatch @relation(fields: [batchId], references: [id])
}

model DocumentTemplate {
  id        String        @id @default(cuid())
  companyId String
  type      DocumentType
  name      String
  description String?
  content   String
  version   Int           @default(1)
  status    DocumentStatus @default(draft)
  placeholders Json?
  requiredPlaceholders Json?
  createdBy String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?
  deletedBy String?
  deletedReason String?

  company Company @relation(fields: [companyId], references: [id])
  documents EmployeeDocument[]
  versions DocumentVersion[]

  @@index([companyId, type])
}

model EmployeeDocument {
  id        String        @id @default(cuid())
  companyId String
  employeeId String
  templateId String?
  payrollRunId String?
  type      DocumentType
  title     String
  status    DocumentStatus @default(draft)
  content   String
  placeholders Json?
  requiredPlaceholders Json?
  month     Int?
  year      Int?
  eventDate DateTime?
  createdBy String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  finalizedAt DateTime?
  reopenedAt DateTime?
  deletedAt DateTime?
  deletedBy String?
  deletedReason String?

  company  Company @relation(fields: [companyId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])
  template DocumentTemplate? @relation(fields: [templateId], references: [id])
  payrollRun PayrollRun? @relation(fields: [payrollRunId], references: [id])
  approvals DocumentApproval[]
  signatures DocumentSignature[]
  versions DocumentVersion[]

  @@index([companyId, employeeId])
  @@index([companyId, type, status])
  @@index([payrollRunId, employeeId, type])
}

model DocumentVersion {
  id        String   @id @default(cuid())
  companyId String
  templateId String?
  documentId String?
  action    String
  reason    String?
  before    Json?
  after     Json?
  createdBy String?
  createdAt DateTime @default(now())

  company  Company @relation(fields: [companyId], references: [id])
  template DocumentTemplate? @relation(fields: [templateId], references: [id])
  document EmployeeDocument? @relation(fields: [documentId], references: [id])

  @@index([templateId])
  @@index([documentId])
}

model DocumentApproval {
  id        String        @id @default(cuid())
  documentId String
  status    DocumentStatus
  reviewerRole UserRole?
  reviewerId String?
  reason    String?
  createdAt DateTime      @default(now())
  decidedAt DateTime?

  document EmployeeDocument @relation(fields: [documentId], references: [id])
}

model DocumentSignature {
  id        String        @id @default(cuid())
  documentId String
  employeeId String?
  userId    String?
  signatureType SignatureType
  tokenHash String?
  ipAddress String?
  deviceInfo String?
  isValid   Boolean       @default(true)
  signedAt  DateTime      @default(now())

  document EmployeeDocument @relation(fields: [documentId], references: [id])
  employee Employee? @relation(fields: [employeeId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  companyId String
  userId    String?
  action    String
  entity    String
  entityId  String?
  reason    String?
  before    Json?
  after     Json?
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])
}

model SupportTicket {
  id          String         @id @default(cuid())
  companyId   String
  employeeId  String?
  title       String
  description String
  status      TicketStatus   @default(open)
  priority    TicketPriority @default(medium)
  category    TicketCategory
  assignedTo  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  company  Company       @relation(fields: [companyId], references: [id])
  employee Employee?     @relation(fields: [employeeId], references: [id])
  messages TicketMessage[]

  @@index([companyId, status])
  @@index([employeeId])
}

model TicketMessage {
  id         String        @id @default(cuid())
  ticketId   String
  userId     String?
  message    String
  sender     String
  senderName String
  createdAt  DateTime      @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id         String   @id @default(cuid())
  companyId  String
  userId     String?
  message    String
  sender     String
  senderName String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model EsocialDocument {
  id                          String                 @id @default(cuid())
  companyId                   String                 @map("company_id")
  externalEventId             String?                @map("external_event_id")
  documentType                EsocialDocumentType    @default(desconhecido) @map("document_type")
  eventType                   String?                @map("event_type")
  employerRegistrationType    String?                @map("employer_registration_type")
  employerRegistrationNumber  String?                @map("employer_registration_number")
  workerCpf                   String?                @map("worker_cpf")
  protocolNumber              String?                @map("protocol_number")
  receiptNumber               String?                @map("receipt_number")
  statusCode                  String?                @map("status_code")
  statusDescription           String?                @map("status_description")
  processingResult            EsocialProcessingResult @default(unknown) @map("processing_result")
  layoutVersion               String?                @map("layout_version")
  namespaceUri                String?                @map("namespace_uri")
  xmlHash                     String                 @map("xml_hash")
  rawXml                      String                 @db.Text @map("raw_xml")
  parsedJson                  Json                   @map("parsed_json")
  parsingError                String?                @db.Text @map("parsing_error")
  xsdValidationStatus         String?                @map("xsd_validation_status")
  xsdValidationErrors         Json?                  @map("xsd_validation_errors")
  createdAt                   DateTime               @default(now()) @map("created_at")
  updatedAt                   DateTime               @updatedAt @map("updated_at")

  company     Company             @relation(fields: [companyId], references: [id])
  occurrences EsocialOccurrence[]

  @@unique([companyId, xmlHash])
  @@index([companyId, documentType])
  @@index([companyId, eventType])
  @@index([companyId, receiptNumber])
  @@index([companyId, protocolNumber])
  @@index([companyId, workerCpf])
  @@map("esocial_documents")
}

model EsocialOccurrence {
  id                          String                  @id @default(cuid())
  documentId                  String                  @map("document_id")
  sourceType                  String                  @map("source_type")
  occurrenceTypeCode          String?                 @map("occurrence_type_code")
  occurrenceTypeLabel         String?                 @map("occurrence_type_label")
  severity                    EsocialOccurrenceSeverity @default(UNKNOWN)
  code                        String?
  description                 String                  @db.Text
  location                    String?
  logicalXpath                String?                 @map("logical_xpath")
  officialCatalogDescription  String?                 @db.Text @map("official_catalog_description")
  probableCause               String?                 @db.Text @map("probable_cause")
  suggestedAction             String?                 @db.Text @map("suggested_action")
  category                    String?
  isBlocking                  Boolean                 @default(false) @map("is_blocking")
  isSuccessCompatible         Boolean                 @default(false) @map("is_success_compatible")
  rawFragment                 String?                 @db.Text @map("raw_fragment")
  createdAt                   DateTime                @default(now()) @map("created_at")

  document EsocialDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([severity])
  @@index([sourceType])
  @@map("esocial_occurrences")
}

model EsocialMessageCatalog {
  code                String   @id
  officialDescription String   @db.Text @map("official_description")
  humanExplanation    String?  @db.Text @map("human_explanation")
  probableCause       String?  @db.Text @map("probable_cause")
  suggestedAction     String?  @db.Text @map("suggested_action")
  category            String?
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("esocial_message_catalog")
}

model SystemConfig {
  id        String   @id @default(cuid())
  companyId String
  key       String
  value     Json
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, key])
}
